---
import '../styles/global.css';
import ChordedApp from '../components/ChordedApp';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Chorded - Chord Converter & Player</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <header class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Chorded</h1>
        <p class="text-gray-600 mt-1">Convert chords and play them in your browser</p>
      </header>

      <ChordedApp client:only="react" />

      <div class="text-sm text-gray-500 py-8">
        <p><strong>Syntax:</strong> Space-separated chords, <code class="bg-gray-100 px-1 rounded">|</code> for bar lines, <code class="bg-gray-100 px-1 rounded">~</code> to extend duration, <code class="bg-gray-100 px-1 rounded">_</code> for rest</p>
        <p class="mt-1">Hover over chords to see their notes.</p>
      </div>
    </div>
  </body>
</html>

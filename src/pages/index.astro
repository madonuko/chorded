---
import '../styles/global.css';
import { parseInput, type TimeSignature, parseTimeSignature } from '../lib/parser';
import { getScaleByName, createScale } from '../lib/scales';
import { formatChordNotes, Chord as ChordClass, NOTATIONS } from '../lib/chord';

const KEY_OPTIONS = ['A', 'A#', 'B', 'C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#'];

const DEFAULT_KEY = 'A';
const DEFAULT_BPM = 132;
const DEFAULT_TIME_SIGNATURE = '4/4';
const DEFAULT_INPUT = 'Am F C E | G D F B | Am F C E | G D F B';

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Chorded - Chord Converter & Player</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <header class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Chorded</h1>
        <p class="text-gray-600 mt-1">Convert chords and play them in your browser</p>
      </header>

      <div class="grid gap-6">
        <div class="grid grid-cols-2 md:grid-cols-6 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Key</label>
            <select id="key-select" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
              {KEY_OPTIONS.map(key => (
                <option value={key} selected={key === DEFAULT_KEY}>{key}</option>
              ))}
            </select>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">BPM</label>
            <input 
              type="number" 
              id="bpm-input"
              value={DEFAULT_BPM}
              min="40"
              max="240"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Time Signature</label>
            <input 
              type="text" 
              id="time-signature-input"
              value={DEFAULT_TIME_SIGNATURE}
              placeholder="4/4"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
            />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">From Notation</label>
            <select id="converter-select" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
              {NOTATIONS.map((notation, i) => (
                <option value={notation.name.en} selected={i === 0}>{notation.name.en}</option>
              ))}
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">To Notation</label>
            <select id="converter-select" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
              {NOTATIONS.map((notation, i) => (
                <option value={notation.name.en} selected={i === 0}>{notation.name.en}</option>
              ))}
            </select>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Chords</label>
          <textarea 
            id="chord-input"
            class="w-full h-32 px-4 py-3 border border-gray-300 rounded-lg font-mono text-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 resize-none"
            placeholder="Enter chords separated by spaces. Use | for bars, ~ to extend, _ for rest."
          >{DEFAULT_INPUT}</textarea>
        </div>

        <div class="flex gap-3">
          <button 
            id="play-btn"
            class="px-6 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors"
          >
            Play
          </button>
          <button 
            id="stop-btn"
            class="px-6 py-2 bg-gray-200 text-gray-700 font-medium rounded-lg hover:bg-gray-300 focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-colors"
          >
            Stop
          </button>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-gray-900 mb-3">Converted</h2>
          <div id="output-container" class="p-4 bg-white rounded-lg border border-gray-200 min-h-[80px]">
            <p class="text-gray-500">Loading...</p>
          </div>
        </div>

        <div id="piano-container" class="p-4 bg-white rounded-lg border border-gray-200">
          <h2 class="text-lg font-semibold text-gray-900 mb-3">Active Notes</h2>
          <div id="active-notes" class="flex gap-2 flex-wrap min-h-[40px]"></div>
        </div>

        <div class="text-sm text-gray-500">
          <p><strong>Syntax:</strong> Space-separated chords, <code class="bg-gray-100 px-1 rounded">|</code> for bar lines, <code class="bg-gray-100 px-1 rounded">~</code> to extend duration, <code class="bg-gray-100 px-1 rounded">_</code> for rest</p>
          <p class="mt-1">Hover over chords to see their notes. Hover over converted chords to see Roman numerals.</p>
        </div>
      </div>
    </div>

    <script>
      import { parseInput, parseTimeSignature } from '../lib/music/parser';
      import { getScaleByName, createScale } from '../lib/music/scales';
      import { getConverter } from '../lib/converters';
      import { formatChordNotes, Chord } from '../lib/music/chord';
      import { initPiano, playChords, stopPlayback } from '../lib/audio/player';

      const inputEl = document.getElementById('chord-input') as HTMLTextAreaElement;
      const keySelect = document.getElementById('key-select') as HTMLSelectElement;
      const bpmInput = document.getElementById('bpm-input') as HTMLInputElement;
      const timeSignatureInput = document.getElementById('time-signature-input') as HTMLInputElement;
      const converterSelect = document.getElementById('converter-select') as HTMLSelectElement;
      const playBtn = document.getElementById('play-btn') as HTMLButtonElement;
      const stopBtn = document.getElementById('stop-btn') as HTMLButtonElement;
      const outputContainer = document.getElementById('output-container');
      const activeNotesContainer = document.getElementById('active-notes');

      let isPlaying = false;

      function getSettings() {
        const timeSignature = parseTimeSignature(timeSignatureInput.value || '4/4');
        return {
          input: inputEl.value,
          key: keySelect.value,
          scale: getScaleByName(keySelect.value) || createScale('A', 'minor'),
          bpm: parseInt(bpmInput.value) || 132,
          timeSignature,
          converter: getConverter(converterSelect.value)
        };
      }

      function formatBeatDuration(duration: number, timeSignature: { numerator: number; denominator: number }): string {
        const beatValue = timeSignature.denominator / 4;
        const beats = duration / beatValue;
        if (beats === 1) return '1';
        if (beats === 0.5) return '½';
        if (beats === 0.25) return '¼';
        if (beats === 1.5) return '1½';
        if (beats === 2) return '2';
        if (beats === 3) return '3';
        if (beats === 4) return '4';
        return beats.toString();
      }

      function updateOutput() {
        const { input, key, scale, timeSignature, converter } = getSettings();
        const parsed = parseInput(input, timeSignature);

        console.log('[Chord Parser] Input:', input);
        console.log('[Chord Parser] Key:', key);
        console.log('[Chord Parser] Time Signature:', `${timeSignature.numerator}/${timeSignature.denominator}`);
        console.log('[Chord Parser] Scale:', scale.notes.join(', '));

        if (!outputContainer || !converter) return;

        let html = '';

        parsed.bars.forEach((bar, barIndex) => {
          html += '<div class="flex flex-wrap gap-2 mb-2 last:mb-0">';

          bar.forEach(item => {
            if (item.isRest) {
              html += '<span class="px-3 py-2 rounded-lg bg-gray-100 text-gray-400">—</span>';
            } else if (item.chord) {
              const converted = converter.convert(item.chord, scale);
              const notes = item.chord.getNotes().map(n => n.toString());
              console.log(`[Chord Parser] Parsed: "${item.chord.toString()}" → Notes: [${notes.join(', ')}]`);
              html += `
                <span
                  class="px-3 py-2 rounded-lg bg-indigo-50 text-indigo-900 hover:bg-indigo-100 cursor-help relative"
                  title="${notes.join(' - ')}"
                >
                  ${converted}
                  <span class="text-xs ml-1 opacity-60">${formatBeatDuration(item.duration, timeSignature)}</span>
                </span>
              `;
            } else {
              html += '<span class="px-3 py-2 rounded-lg bg-red-50 text-red-500">?</span>';
            }
          });

          if (barIndex < parsed.bars.length - 1) {
            html += '<span class="text-gray-400 self-center">|</span>';
          }

          html += '</div>';
        });

        outputContainer.innerHTML = html;
      }

      async function startPlayback() {
        if (isPlaying) {
          stopPlayback();
          isPlaying = false;
          playBtn.textContent = 'Play';
          return;
        }

        const { input, scale, bpm, timeSignature } = getSettings();
        const parsed = parseInput(input, timeSignature);

        try {
          await initPiano();
          
          isPlaying = true;
          playBtn.textContent = 'Playing...';
          
          await playChords(
            parsed,
            scale,
            bpm,
            (notes) => {
              if (activeNotesContainer) {
                activeNotesContainer.innerHTML = notes.map(n => 
                  `<span class="px-2 py-1 bg-green-100 text-green-800 rounded text-sm">${n}</span>`
                ).join('');
              }
            },
            () => {
              if (activeNotesContainer) {
                activeNotesContainer.innerHTML = '';
              }
            }
          );
        } catch (err) {
          console.error('Playback error:', err);
        } finally {
          isPlaying = false;
          playBtn.textContent = 'Play';
        }
      }

      function stop() {
        stopPlayback();
        isPlaying = false;
        playBtn.textContent = 'Play';
        if (activeNotesContainer) {
          activeNotesContainer.innerHTML = '';
        }
      }

      inputEl.addEventListener('input', updateOutput);
      keySelect.addEventListener('change', updateOutput);
      bpmInput.addEventListener('input', updateOutput);
      timeSignatureInput.addEventListener('input', updateOutput);
      converterSelect.addEventListener('change', updateOutput);
      playBtn.addEventListener('click', startPlayback);
      stopBtn.addEventListener('click', stop);

      updateOutput();
    </script>
  </body>
</html>
